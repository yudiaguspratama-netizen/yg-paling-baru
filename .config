# Target Hardware
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_zte_e8820v2=y

# Hapus LuCI (Web UI) Total
# CONFIG_PACKAGE_luci is not set
CONFIG_PACKAGE_luci-mod-admin-full=n
CONFIG_PACKAGE_luci-theme-bootstrap=n
CONFIG_PACKAGE_uhttpd=n
CONFIG_PACKAGE_rpcd=n

# Matikan Firewall & NAT (Pure Routing)
CONFIG_PACKAGE_firewall4=n
CONFIG_PACKAGE_nftables=n
CONFIG_PACKAGE_kmod-nft-core=n
CONFIG_PACKAGE_kmod-nft-nat=n

# Driver Wireless (Wajib Ada)
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# Driver LAN/Ethernet Switch
CONFIG_PACKAGE_kmod-mt753x-sw=y

# Optimasi Ghost Engine (Minimalisir RAM)
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_STRIP=y
CONFIG_USE_SSTRIP=y
CONFIG_PACKAGE_zram-stats=y
CONFIG_PACKAGE_kmod-zram=y

# Hapus Fitur yang Tidak Diperlukan
# CONFIG_PACKAGE_ppp is not set (Gunakan 'y' jika butuh PPPoE)
# CONFIG_PACKAGE_odhcpd is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
