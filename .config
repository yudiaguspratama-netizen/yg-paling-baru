# --- Target Hardware ---
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_zte_e8820v2=y

# --- Core UI (Hanya Bootstrap yang Paling Ringan) ---
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_en=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# --- Optimasi RAM (WAJIB) ---
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-zram=y
# Menggunakan wolfssl-tiny/basic untuk menghemat sekitar 1-2MB RAM
CONFIG_PACKAGE_wpad-basic-wolfssl=y

# --- Driver WiFi Minimalis ---
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7615-firmware=y
CONFIG_PACKAGE_kmod-mt7615e=y

# --- Limit Bandwidth (Paling Hemat) ---
# Kita gunakan EQOS biasa, karena EQOSPlus butuh lebih banyak library iptables
CONFIG_PACKAGE_luci-app-eqos=y
CONFIG_PACKAGE_tc-tiny=y
CONFIG_PACKAGE_kmod-sched-core=y

# --- BUANG FITUR UNTUK HEMAT RAM (PENTING) ---
# Mematikan fitur logging dan statistik yang memakan RAM
# CONFIG_PACKAGE_luci-app-statistics is not set
# CONFIG_PACKAGE_collectd is not set
# Mematikan service discovery yang tidak terlalu penting
# CONFIG_PACKAGE_avahi-dbus-daemon is not set
# Menggunakan dnsmasq versi full kadang berat, tapi untuk 64MB standar sudah ok
