# --- Target Hardware ---
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_zte_e8820v2=y

# --- HAPUS SELURUH GUI (LuCI) ---
# CONFIG_PACKAGE_luci is not set

# --- WiFi & Driver (Wajib Ada) ---
CONFIG_PACKAGE_wpad-basic-wolfssl=y
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7615-firmware=y
CONFIG_PACKAGE_kmod-mt7615e=y

# --- Fitur Inti (System Core) ---
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_tc-tiny=y
CONFIG_PACKAGE_kmod-sched-core=y

# --- Pembersihan Protokol ---
# CONFIG_IPV6 is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
