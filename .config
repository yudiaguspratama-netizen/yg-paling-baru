# --- Target Hardware ---
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_zte_e8820v2=y

# --- LuCI Dasar (Super Ringan) ---
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_en=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# --- Buang Menu Software & Fitur GUI Berat ---
# CONFIG_PACKAGE_luci-app-opkg is not set
# CONFIG_PACKAGE_luci-app-filebrowser is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-turboacc is not set
# CONFIG_PACKAGE_luci-app-diagnostics is not set
# CONFIG_PACKAGE_luci-app-statistics is not set
# CONFIG_PACKAGE_luci-app-nlbwmon is not set
# CONFIG_PACKAGE_luci-app-logread is not set

# --- WiFi & Security (Optimasi Memori) ---
CONFIG_PACKAGE_wpad-basic-wolfssl=y
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7615-firmware=y
CONFIG_PACKAGE_kmod-mt7615e=y

# --- Optimasi RAM Dasar ---
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-zram=y

# --- Buang Driver & Protokol Tidak Terpakai ---
# CONFIG_IPV6 is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_kmod-ppp is not set

# --- Buang Diagnostik & Logging ---
# CONFIG_PACKAGE_tcpdump is not set
# CONFIG_PACKAGE_iw-full is not set
CONFIG_PACKAGE_iw-light=y
